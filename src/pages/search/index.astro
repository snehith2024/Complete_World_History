---
import Layout from '../../layouts/Layout.astro';
import events from '../../data/events.json';
import civs from '../../data/civilizations.json';
import figures from '../../data/figures.json';

// Read query from URL
const q = Astro.url.searchParams.get('q') ?? '';

// Simple search across all data
const searchResults: Array<{ type: string; item: any; score: number }> = [];

if (q) {
  const lower = q.toLowerCase();

  events.forEach(ev => {
    const score = (ev.title.toLowerCase().includes(lower) ? 3 : 0)
      + (ev.description?.toLowerCase().includes(lower) ? 2 : 0)
      + (ev.era.toLowerCase().includes(lower) ? 1 : 0);
    if (score > 0) searchResults.push({ type: 'event', item: ev, score });
  });

  civs.forEach(civ => {
    const score = (civ.name.toLowerCase().includes(lower) ? 3 : 0)
      + (civ.description.toLowerCase().includes(lower) ? 2 : 0)
      + (civ.region.toLowerCase().includes(lower) ? 1 : 0);
    if (score > 0) searchResults.push({ type: 'civilization', item: civ, score });
  });

  figures.forEach(fig => {
    const score = (fig.name.toLowerCase().includes(lower) ? 3 : 0)
      + (fig.biography.toLowerCase().includes(lower) ? 2 : 0)
      + (fig.role.toLowerCase().includes(lower) ? 1 : 0);
    if (score > 0) searchResults.push({ type: 'figure', item: fig, score });
  });

  searchResults.sort((a, b) => b.score - a.score);
}

const typeColors: Record<string, string> = {
  event: '#007cf0',
  civilization: '#f5a623',
  figure: '#7928ca',
};
const typeIcons: Record<string, string> = {
  event: '⚡',
  civilization: '🏛️',
  figure: '👤',
};
---

<Layout
  title={q ? `Search: "${q}"` : 'Search World History'}
  description="Search through thousands of historical events, civilizations, and figures from across world history."
>
  <div class="search-page" style="padding-top: var(--nav-height)">
    <!-- Search hero -->
    <div class="search-page-hero">
      <div class="container-content search-hero-inner">
        <h1 class="text-display-lg search-page-heading">
          {q ? <>Results for <span class="gradient-text-develop">"{q}"</span></> : 'Search World History'}
        </h1>

        <!-- Search input -->
        <form class="search-page-form" action="/search" method="get" role="search">
          <div class="search-input-row">
            <svg class="search-pg-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M13 13L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <input
              type="search"
              name="q"
              id="search-page-input"
              class="search-page-input"
              value={q}
              placeholder="Search events, civilizations, figures..."
              autofocus
              aria-label="Search world history"
            />
            <button type="submit" class="btn btn-primary search-page-btn">
              Search
            </button>
          </div>
        </form>

        {q && (
          <p class="search-count text-mono">
            {searchResults.length} result{searchResults.length !== 1 ? 's' : ''} for "{q}"
          </p>
        )}
      </div>
    </div>

    <!-- Results -->
    <div class="container-content search-results section">
      {!q && (
        <div class="search-empty">
          <p class="text-body-lg text-body text-center">Enter a search term to explore world history.</p>
          <div class="search-suggestions-grid">
            <div class="search-sug-group">
              <p class="eyebrow">Popular Searches</p>
              <div class="sug-chips">
                {['Julius Caesar', 'Roman Empire', 'Ancient Egypt', 'Genghis Khan', 'World War II', 'Renaissance', 'Alexander the Great'].map(s => (
                  <a href={`/search?q=${encodeURIComponent(s)}`} class="sug-chip">{s}</a>
                ))}
              </div>
            </div>
            <div class="search-sug-group">
              <p class="eyebrow">By Era</p>
              <div class="sug-chips">
                {['Ancient civilizations', 'Classical era', 'Medieval period', 'Industrial revolution', 'Modern history'].map(s => (
                  <a href={`/search?q=${encodeURIComponent(s)}`} class="sug-chip">{s}</a>
                ))}
              </div>
            </div>
          </div>
        </div>
      )}

      {q && searchResults.length === 0 && (
        <div class="search-no-results text-center">
          <p class="text-display-sm" style="color: var(--color-mute)">No results found.</p>
          <p class="text-body-md text-body">Try searching for a civilization, historical figure, or event.</p>
          <a href="/timeline" class="btn btn-primary" style="margin-top: var(--space-md); height: 44px; padding: 0 var(--space-xl); border-radius: var(--radius-pill);">
            Browse the Timeline →
          </a>
        </div>
      )}

      {q && searchResults.length > 0 && (
        <div class="search-results-list">
          {searchResults.map((result, i) => {
            const { type, item } = result;
            const href = type === 'event' ? `/timeline#${item.id}`
                        : type === 'civilization' ? `/civilizations/${item.id}`
                        : `/figures/${item.id}`;
            const yearText = type === 'event'
              ? (item.year < 0 ? `${Math.abs(item.year)} BCE` : `${item.year} CE`)
              : type === 'civilization'
              ? `${item.start < 0 ? Math.abs(item.start) + ' BCE' : item.start + ' CE'} – ${item.end < 0 ? Math.abs(item.end) + ' BCE' : item.end + ' CE'}`
              : `${item.born < 0 ? Math.abs(item.born) + ' BCE' : item.born + ' CE'} – ${item.died < 0 ? Math.abs(item.died) + ' BCE' : item.died + ' CE'}`;

            return (
              <a href={href} class="search-result-card animate-fade-in-up" style={`animation-delay: ${i * 50}ms; --rc: ${typeColors[type] ?? '#007cf0'}`}>
                <div class="sr-type-icon" aria-label={type}>{typeIcons[type] ?? '•'}</div>
                <div class="sr-body">
                  <div class="sr-meta">
                    <span class="sr-type-badge text-mono">{type}</span>
                    <span class="sr-year text-mono">{yearText}</span>
                    {type === 'event' && <span class="sr-era text-mono">{item.era}</span>}
                  </div>
                  <h2 class="sr-title text-display-sm">
                    {type === 'event' ? item.title : type === 'civilization' ? item.name : item.name}
                  </h2>
                  <p class="sr-desc text-body-sm">
                    {type === 'event' ? item.description : type === 'civilization' ? item.description : item.significance}
                  </p>
                </div>
                <svg class="sr-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M10 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .search-page-hero {
    padding: var(--space-4xl) 0 var(--space-3xl);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-soft);
  }
  .search-hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .search-page-heading { letter-spacing: -1.5px; }

  .search-page-form { width: 100%; }
  .search-input-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 var(--space-sm);
    height: 56px;
    max-width: 700px;
    transition: border-color var(--transition-fast);
  }
  .search-input-row:focus-within { border-color: var(--color-border-focus); }
  .search-pg-icon { color: var(--color-mute); flex-shrink: 0; }
  .search-page-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: var(--text-body-lg);
    color: var(--color-ink);
  }
  .search-page-input::placeholder { color: var(--color-mute); }
  .search-page-btn {
    height: 40px;
    padding: 0 var(--space-lg);
    font-size: var(--text-body-sm);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }
  .search-count { font-size: 11px; color: var(--color-mute); }

  /* Results */
  .search-results-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .search-result-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: var(--transition-normal);
    border-left: 3px solid var(--rc, var(--color-border));
  }
  .search-result-card:hover {
    transform: translateX(4px);
    border-color: var(--rc, var(--color-border-strong));
    box-shadow: var(--shadow-2);
  }
  .search-result-card:hover .sr-arrow { transform: translateX(4px); }

  .sr-type-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
  .sr-body { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .sr-meta { display: flex; align-items: center; gap: var(--space-xs); flex-wrap: wrap; }
  .sr-type-badge {
    font-size: 9px;
    color: var(--rc);
    background: color-mix(in srgb, var(--rc) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--rc) 25%, transparent);
    border-radius: var(--radius-full);
    padding: 2px 7px;
    text-transform: uppercase;
  }
  .sr-year, .sr-era { font-size: 10px; color: var(--color-mute); }
  .sr-title { font-size: 17px; font-weight: 600; letter-spacing: -0.3px; }
  .sr-desc { color: var(--color-body); font-size: 13px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .sr-arrow { flex-shrink: 0; color: var(--color-mute); transition: transform var(--transition-fast); margin-top: 4px; }

  /* Empty */
  .search-empty { display: flex; flex-direction: column; gap: var(--space-xl); align-items: center; }
  .search-suggestions-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); width: 100%; max-width: 700px; }
  .search-sug-group { display: flex; flex-direction: column; gap: var(--space-sm); }
  .sug-chips { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
  .sug-chip {
    font-size: 13px;
    color: var(--color-body);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 5px var(--space-sm);
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .sug-chip:hover { background: var(--color-bg-hover); color: var(--color-ink); border-color: var(--color-border-strong); }

  .search-no-results { display: flex; flex-direction: column; align-items: center; gap: var(--space-md); padding-block: var(--space-4xl); }

  @media (max-width: 599px) { .search-suggestions-grid { grid-template-columns: 1fr; } }
</style>
