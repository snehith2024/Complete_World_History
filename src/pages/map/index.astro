---
import Layout from '../../layouts/Layout.astro';
import empires from '../../data/empires.json';
import eras from '../../data/eras.json';
---

<Layout
  title="Historical Atlas"
  description="Watch empires rise and fall across millennia. Explore every kingdom, empire, and civilization from the dawn of history to the modern world on an interactive map."
  fullscreen={true}
  noNav={true}
  noFooter={true}
>
  <div class="atlas-app" id="atlas-app"
    data-empires={JSON.stringify(empires)}
    data-eras={JSON.stringify(eras)}
  >
    <!-- Header -->
    <header class="atlas-header">
      <div class="atlas-header-left">
        <a href="/" class="atlas-back" aria-label="Back to home">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="atlas-title-group">
          <h1 class="atlas-title">Historical Atlas</h1>
          <span class="atlas-year-badge" id="year-badge">500 BCE</span>
        </div>
      </div>

      <div class="atlas-header-center">
        <!-- Empire search/selector -->
        <div class="atlas-search">
          <svg class="atlas-search-icon" width="12" height="12" viewBox="0 0 14 14" fill="none">
            <circle cx="5.5" cy="5.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 9L13 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <select class="atlas-select" id="empire-select" aria-label="Jump to empire">
            <option value="">All Empires</option>
            {empires.sort((a, b) => a.start - b.start).map(emp => (
              <option value={emp.id}>{emp.name} ({emp.start < 0 ? Math.abs(emp.start) + ' BCE' : emp.start + ' CE'})</option>
            ))}
          </select>
        </div>
      </div>

      <div class="atlas-header-right">
        <!-- Play button -->
        <button class="atlas-play-btn" id="play-btn" aria-label="Play timeline animation">
          <svg width="10" height="12" viewBox="0 0 10 12" fill="none" id="play-icon">
            <path d="M1 1l8 5-8 5V1z" fill="currentColor"/>
          </svg>
          <svg width="10" height="12" viewBox="0 0 10 12" fill="none" id="pause-icon" style="display:none">
            <rect x="1" y="1" width="3" height="10" fill="currentColor"/>
            <rect x="6" y="1" width="3" height="10" fill="currentColor"/>
          </svg>
        </button>

        <!-- Speed control -->
        <div class="atlas-speed" id="speed-group">
          <button class="atlas-speed-btn active" data-speed="1">1×</button>
          <button class="atlas-speed-btn" data-speed="3">3×</button>
          <button class="atlas-speed-btn" data-speed="10">10×</button>
        </div>
      </div>
    </header>

    <!-- Map -->
    <div class="atlas-map-area">
      <div id="leaflet-map" class="atlas-map"></div>

      <!-- Legend panel -->
      <div class="atlas-legend" id="atlas-legend">
        <div class="atlas-legend-header">
          <span class="atlas-legend-title">Active Empires</span>
          <button class="atlas-legend-toggle" id="legend-toggle" aria-label="Toggle legend">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <div class="atlas-legend-items" id="legend-items"></div>
        <div class="atlas-legend-empty" id="legend-empty">
          <span>Drag the slider to explore history</span>
        </div>
      </div>

      <!-- Empire info panel -->
      <div class="atlas-info" id="atlas-info">
        <button class="atlas-info-close" id="info-close" aria-label="Close">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="atlas-info-header">
          <span class="atlas-info-era" id="info-era"></span>
          <span class="atlas-info-dates" id="info-dates"></span>
        </div>
        <h2 class="atlas-info-title" id="info-title"></h2>
        <p class="atlas-info-desc" id="info-desc"></p>
        <div class="atlas-info-sig" id="info-sig"></div>
        <div class="atlas-info-meta">
          <div class="atlas-info-meta-row" id="info-capital-row">
            <span class="atlas-info-label">Capital</span>
            <span class="atlas-info-value" id="info-capital"></span>
          </div>
          <div class="atlas-info-meta-row" id="info-region-row">
            <span class="atlas-info-label">Region</span>
            <span class="atlas-info-value" id="info-region"></span>
          </div>
        </div>
        <div class="atlas-info-tags" id="info-tags"></div>
        <button class="atlas-info-timeline-btn" id="info-timeline-btn">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M1 6h10M4 3l-3 3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          View on Timeline
        </button>
      </div>
    </div>

    <!-- Timeline scrubber -->
    <div class="atlas-scrubber">
      <div class="atlas-scrubber-row">
        <span class="atlas-scrubber-edge">3500 BCE</span>
        <div class="atlas-scrubber-track">
          <input
            type="range"
            id="year-slider"
            class="atlas-slider"
            min="-3500"
            max="2026"
            value="-500"
            step="1"
            aria-label="Navigate through history"
          />
          <!-- Era color bar -->
          <div class="atlas-era-bar" aria-hidden="true">
            <div class="era-segment" style="background:#f5a623;width:24.3%" title="Ancient"></div>
            <div class="era-segment" style="background:#00dfd8;width:11.8%" title="Classical"></div>
            <div class="era-segment" style="background:#9c5de8;width:16.3%" title="Medieval"></div>
            <div class="era-segment" style="background:#007cf0;width:7.2%" title="Early Modern"></div>
            <div class="era-segment" style="background:#ff4d4d;width:2.1%" title="Industrial"></div>
            <div class="era-segment" style="background:#50e3c2;width:1.6%" title="Modern"></div>
            <div class="era-segment" style="background:#aaffec;width:0.4%" title="Present"></div>
          </div>
        </div>
        <span class="atlas-scrubber-edge">2026 CE</span>
      </div>
      <div class="atlas-era-labels">
        <button class="atlas-era-btn" data-year="-3500" data-zoom="4">Ancient</button>
        <button class="atlas-era-btn" data-year="-500" data-zoom="3">Classical</button>
        <button class="atlas-era-btn" data-year="900" data-zoom="3">Medieval</button>
        <button class="atlas-era-btn" data-year="1500" data-zoom="3">Early Modern</button>
        <button class="atlas-era-btn" data-year="1800" data-zoom="3">Industrial</button>
        <button class="atlas-era-btn" data-year="1950" data-zoom="3">Modern</button>
      </div>
    </div>
  </div>
</Layout>

<style>
  .atlas-app {
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
    background: #030712;
    color: #f0f4f8;
  }

  /* ─── Header ─── */
  .atlas-header {
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 0 16px;
    background: rgba(3, 7, 18, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    flex-shrink: 0;
    z-index: 1000;
  }
  .atlas-header-left, .atlas-header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .atlas-header-center {
    flex: 1;
    display: flex;
    justify-content: center;
    max-width: 400px;
    margin: 0 auto;
  }

  .atlas-back {
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px;
    color: rgba(255,255,255,0.4);
    transition: all 0.15s;
    text-decoration: none;
  }
  .atlas-back:hover {
    background: rgba(255,255,255,0.06);
    color: #fff;
  }

  .atlas-title-group { display: flex; align-items: center; gap: 10px; }
  .atlas-title {
    font-size: 15px; font-weight: 600;
    font-family: 'Inter', system-ui, sans-serif;
    letter-spacing: -0.3px;
    color: #f0f4f8;
  }
  .atlas-year-badge {
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    padding: 2px 10px;
    border-radius: 20px;
    background: rgba(0, 223, 216, 0.1);
    color: #00dfd8;
    border: 1px solid rgba(0, 223, 216, 0.2);
    font-weight: 500;
  }

  /* Search / Select */
  .atlas-search {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 0 10px;
    width: 100%;
  }
  .atlas-search-icon { color: rgba(255,255,255,0.25); flex-shrink: 0; }
  .atlas-select {
    height: 30px; width: 100%;
    background: transparent;
    border: none;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    outline: none;
    cursor: pointer;
    -webkit-appearance: none;
  }
  .atlas-select option { background: #171717; color: #f0f4f8; }

  /* Play button */
  .atlas-play-btn {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(0, 223, 216, 0.3);
    background: rgba(0, 223, 216, 0.08);
    color: #00dfd8;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .atlas-play-btn:hover {
    background: rgba(0, 223, 216, 0.15);
    border-color: rgba(0, 223, 216, 0.5);
    box-shadow: 0 0 20px rgba(0, 223, 216, 0.15);
  }
  .atlas-play-btn.playing {
    background: rgba(0, 223, 216, 0.15);
    border-color: #00dfd8;
    box-shadow: 0 0 20px rgba(0, 223, 216, 0.2);
  }

  /* Speed */
  .atlas-speed {
    display: flex;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    padding: 1px;
    gap: 1px;
  }
  .atlas-speed-btn {
    font-size: 10px; padding: 3px 8px;
    border-radius: 4px; border: none;
    background: none;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    transition: all 0.15s;
  }
  .atlas-speed-btn:hover { color: rgba(255,255,255,0.6); }
  .atlas-speed-btn.active {
    background: rgba(0, 223, 216, 0.1);
    color: #00dfd8;
  }

  /* ─── Map ─── */
  .atlas-map-area {
    flex: 1;
    position: relative;
    min-height: 0;
  }
  .atlas-map {
    width: 100%; height: 100%;
    background: #070d18;
  }

  /* ─── Legend ─── */
  .atlas-legend {
    position: absolute;
    top: 12px; left: 12px;
    width: 220px;
    background: rgba(5, 10, 25, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    z-index: 500;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    overflow: hidden;
    transition: all 0.25s;
  }
  .atlas-legend.collapsed .atlas-legend-items,
  .atlas-legend.collapsed .atlas-legend-empty { display: none; }
  .atlas-legend.collapsed { width: auto; }

  .atlas-legend-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .atlas-legend-title {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.35);
  }
  .atlas-legend-toggle {
    width: 20px; height: 20px;
    border: none; background: none;
    color: rgba(255,255,255,0.3);
    cursor: pointer; display: flex;
    align-items: center; justify-content: center;
    border-radius: 4px;
    transition: all 0.15s;
  }
  .atlas-legend-toggle:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .atlas-legend.collapsed .atlas-legend-toggle svg { transform: rotate(-90deg); }

  .atlas-legend-items {
    padding: 6px 10px 10px;
    max-height: 300px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .atlas-legend-items::-webkit-scrollbar { width: 3px; }
  .atlas-legend-items::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

  .legend-row {
    display: flex; align-items: center; gap: 8px;
    padding: 4px 6px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 11px;
    color: rgba(255,255,255,0.65);
    font-family: 'Inter', system-ui, sans-serif;
  }
  .legend-row:hover { background: rgba(255,255,255,0.04); color: #fff; }
  .legend-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 6px currentColor;
  }
  .legend-date {
    font-size: 9px;
    color: rgba(255,255,255,0.25);
    font-family: 'JetBrains Mono', monospace;
    margin-left: auto;
    white-space: nowrap;
  }

  .atlas-legend-empty {
    padding: 12px 14px;
    font-size: 11px;
    color: rgba(255,255,255,0.2);
    font-style: italic;
    text-align: center;
  }

  /* ─── Info Panel ─── */
  .atlas-info {
    position: absolute;
    top: 12px; right: 12px;
    width: 340px;
    max-height: calc(100% - 24px);
    overflow-y: auto;
    background: rgba(5, 10, 25, 0.94);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(0, 223, 216, 0.12);
    border-radius: 14px;
    padding: 24px;
    z-index: 500;
    box-shadow: 0 0 50px rgba(0, 223, 216, 0.04), 0 16px 48px rgba(0,0,0,0.5);
    transform: translateX(120%);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }
  .atlas-info.visible {
    transform: translateX(0);
    opacity: 1;
  }
  .atlas-info::-webkit-scrollbar { width: 3px; }
  .atlas-info::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 3px; }

  .atlas-info-close {
    position: absolute; top: 14px; right: 14px;
    width: 28px; height: 28px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.3);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.15s;
  }
  .atlas-info-close:hover { background: rgba(255,255,255,0.08); color: #fff; }

  .atlas-info-header {
    display: flex; align-items: center; gap: 10px; margin-bottom: 12px;
  }
  .atlas-info-era {
    font-size: 9px; font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(0, 223, 216, 0.1);
    color: #00dfd8;
    border: 1px solid rgba(0, 223, 216, 0.2);
  }
  .atlas-info-dates {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    font-family: 'JetBrains Mono', monospace;
  }
  .atlas-info-title {
    font-size: 20px; font-weight: 700;
    color: #f0f4f8;
    line-height: 1.3; margin: 0 0 14px;
    font-family: 'Inter', system-ui, sans-serif;
  }
  .atlas-info-desc {
    font-size: 13px; line-height: 1.7;
    color: rgba(255,255,255,0.6);
    margin: 0 0 14px;
    font-family: 'Inter', system-ui, sans-serif;
  }
  .atlas-info-sig {
    font-size: 12px;
    color: rgba(0, 223, 216, 0.65);
    font-style: italic;
    padding: 10px 14px;
    background: rgba(0, 223, 216, 0.03);
    border-left: 2px solid rgba(0, 223, 216, 0.25);
    border-radius: 0 8px 8px 0;
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .atlas-info-sig:empty { display: none; }

  .atlas-info-meta {
    display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px;
  }
  .atlas-info-meta-row {
    display: flex; justify-content: space-between; align-items: center;
  }
  .atlas-info-label {
    font-size: 10px; font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.25);
  }
  .atlas-info-value {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    font-family: 'Inter', system-ui, sans-serif;
  }

  .atlas-info-tags {
    display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 16px;
  }
  .atlas-info-tags:empty { display: none; }
  .atlas-info-tag {
    font-size: 9px; padding: 2px 8px;
    border-radius: 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.4);
    font-family: 'JetBrains Mono', monospace;
  }

  .atlas-info-timeline-btn {
    display: flex; align-items: center; gap: 6px;
    width: 100%; padding: 10px 14px;
    border-radius: 8px;
    border: 1px solid rgba(0, 223, 216, 0.15);
    background: rgba(0, 223, 216, 0.04);
    color: rgba(0, 223, 216, 0.7);
    font-size: 12px;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .atlas-info-timeline-btn:hover {
    background: rgba(0, 223, 216, 0.08);
    border-color: rgba(0, 223, 216, 0.3);
    color: #00dfd8;
  }

  /* ─── Scrubber ─── */
  .atlas-scrubber {
    background: rgba(3, 7, 18, 0.94);
    backdrop-filter: blur(16px);
    border-top: 1px solid rgba(255,255,255,0.04);
    padding: 10px 20px 8px;
    flex-shrink: 0;
    z-index: 1000;
  }
  .atlas-scrubber-row {
    display: flex; align-items: center; gap: 12px;
  }
  .atlas-scrubber-edge {
    font-size: 9px;
    color: rgba(255,255,255,0.2);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
    flex-shrink: 0;
    width: 60px;
    text-align: center;
  }
  .atlas-scrubber-track {
    flex: 1;
    position: relative;
  }

  .atlas-slider {
    width: 100%;
    height: 6px;
    -webkit-appearance: none;
    background: transparent;
    outline: none;
    cursor: pointer;
    position: relative;
    z-index: 2;
  }
  .atlas-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: #00dfd8;
    border: 2px solid #030712;
    box-shadow: 0 0 12px rgba(0, 223, 216, 0.4), 0 0 4px rgba(0, 223, 216, 0.6);
    cursor: pointer;
    position: relative;
    z-index: 3;
  }
  .atlas-slider::-moz-range-thumb {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: #00dfd8;
    border: 2px solid #030712;
    box-shadow: 0 0 12px rgba(0, 223, 216, 0.4);
    cursor: pointer;
  }

  .atlas-era-bar {
    position: absolute;
    top: 50%; left: 0; right: 0;
    height: 4px;
    transform: translateY(-50%);
    display: flex;
    border-radius: 2px;
    overflow: hidden;
    z-index: 1;
    opacity: 0.4;
  }
  .era-segment { height: 100%; }

  .atlas-era-labels {
    display: flex;
    justify-content: space-between;
    padding: 6px 60px 0;
  }
  .atlas-era-btn {
    font-size: 9px;
    font-family: 'JetBrains Mono', monospace;
    color: rgba(255,255,255,0.2);
    background: none; border: none;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 4px;
    transition: all 0.15s;
  }
  .atlas-era-btn:hover {
    color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.04);
  }

  /* ─── Leaflet Overrides ─── */
  :global(.leaflet-popup-content-wrapper) {
    background: rgba(5, 10, 25, 0.95) !important;
    border: 1px solid rgba(0, 223, 216, 0.15) !important;
    border-radius: 12px !important;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
    color: #f0f4f8 !important;
    font-family: 'Inter', system-ui, sans-serif !important;
  }
  :global(.leaflet-popup-content) {
    margin: 12px 16px !important;
    font-size: 13px !important;
    line-height: 1.5 !important;
  }
  :global(.leaflet-popup-tip) {
    background: rgba(5, 10, 25, 0.95) !important;
    border: 1px solid rgba(0, 223, 216, 0.1) !important;
  }
  :global(.leaflet-control-zoom) {
    border: 1px solid rgba(255,255,255,0.06) !important;
    border-radius: 8px !important;
    overflow: hidden;
  }
  :global(.leaflet-control-zoom a) {
    background: rgba(5, 10, 25, 0.9) !important;
    color: rgba(255,255,255,0.5) !important;
    border-color: rgba(255,255,255,0.06) !important;
    width: 30px !important;
    height: 30px !important;
    line-height: 30px !important;
    font-size: 14px !important;
  }
  :global(.leaflet-control-zoom a:hover) {
    background: rgba(5, 10, 25, 1) !important;
    color: #fff !important;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .atlas-header-center { display: none; }
    .atlas-speed { display: none; }
    .atlas-legend { width: 180px; }
    .atlas-info { width: calc(100% - 24px); right: 12px; left: 12px; }
    .atlas-era-labels { padding: 6px 20px 0; }
  }
  @media (max-width: 480px) {
    .atlas-legend { display: none; }
    .atlas-era-labels { display: none; }
    .atlas-scrubber { padding: 8px 12px 6px; }
  }
</style>

<script>
  // ─────────────────────────────────────────────
  // HISTORICAL ATLAS — Interactive Map Engine
  // ─────────────────────────────────────────────

  async function initAtlas() {
    var leafletModule = await import('leaflet');
    var L = leafletModule.default || leafletModule;

    // Inject Leaflet CSS
    if (!document.getElementById('leaflet-css')) {
      var link = document.createElement('link');
      link.id = 'leaflet-css';
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      document.head.appendChild(link);
    }

    var appEl = document.getElementById('atlas-app');
    var mapEl = document.getElementById('leaflet-map');
    if (!appEl || !mapEl) return;

    // ─── Parse Data ───
    var empires = [];
    var eras = [];
    try {
      empires = JSON.parse(appEl.dataset.empires || '[]');
      eras = JSON.parse(appEl.dataset.eras || '[]');
    } catch(e) {}

    // ─── Initialize Map ───
    var map = L.map(mapEl, {
      center: [25, 30],
      zoom: 3,
      zoomControl: false,
      minZoom: 2,
      maxZoom: 8,
      worldCopyJump: true,
    });

    // Dark tile layer
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OSM &copy; CARTO',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map);

    // Labels layer on top
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_only_labels/{z}/{x}/{y}{r}.png', {
      subdomains: 'abcd',
      maxZoom: 19,
      pane: 'overlayPane',
    }).addTo(map);

    L.control.zoom({ position: 'topright' }).addTo(map);

    // ─── State ───
    var currentYear = -500;
    var activeLayers = [];
    var selectedEmpire = null;
    var playing = false;
    var playInterval = null;
    var playSpeed = 1;

    // ─── DOM Elements ───
    var slider = document.getElementById('year-slider');
    var yearBadge = document.getElementById('year-badge');
    var legendItems = document.getElementById('legend-items');
    var legendEmpty = document.getElementById('legend-empty');
    var infoPanel = document.getElementById('atlas-info');
    var infoClose = document.getElementById('info-close');
    var infoEra = document.getElementById('info-era');
    var infoDates = document.getElementById('info-dates');
    var infoTitle = document.getElementById('info-title');
    var infoDesc = document.getElementById('info-desc');
    var infoSig = document.getElementById('info-sig');
    var infoCapital = document.getElementById('info-capital');
    var infoRegion = document.getElementById('info-region');
    var infoTags = document.getElementById('info-tags');
    var infoTimelineBtn = document.getElementById('info-timeline-btn');
    var playBtn = document.getElementById('play-btn');
    var playIcon = document.getElementById('play-icon');
    var pauseIcon = document.getElementById('pause-icon');
    var empireSelect = document.getElementById('empire-select');
    var legendToggle = document.getElementById('legend-toggle');
    var legendPanel = document.getElementById('atlas-legend');

    // ─── Utility ───
    function formatYear(y) {
      if (y < 0) return Math.abs(y) + ' BCE';
      if (y === 0) return '1 CE';
      return y + ' CE';
    }

    function getEraName(eraId) {
      for (var i = 0; i < eras.length; i++) {
        if (eras[i].id === eraId) return eras[i].shortName || eras[i].name;
      }
      return eraId || '';
    }

    function hexToRgba(hex, a) {
      var r = parseInt(hex.slice(1,3), 16);
      var g = parseInt(hex.slice(3,5), 16);
      var b = parseInt(hex.slice(5,7), 16);
      return 'rgba(' + r + ',' + g + ',' + b + ',' + a + ')';
    }

    // ─── Map Update ───
    function updateMapForYear(year) {
      // Remove old layers
      activeLayers.forEach(function(l) { map.removeLayer(l); });
      activeLayers = [];

      var activeEmpires = [];

      empires.forEach(function(emp) {
        if (year >= emp.start && year <= emp.end) {
          activeEmpires.push(emp);

          // Calculate age-based opacity (stronger at peak)
          var span = emp.end - emp.start;
          var age = (year - emp.start) / (span || 1);
          var peakAge = emp.peakYear ? (emp.peakYear - emp.start) / (span || 1) : 0.5;
          var distFromPeak = Math.abs(age - peakAge);
          var fillOp = 0.08 + (1 - distFromPeak) * 0.18;
          var strokeOp = 0.3 + (1 - distFromPeak) * 0.5;

          var polygon = L.polygon(emp.coords, {
            color: emp.color,
            fillColor: emp.color,
            fillOpacity: fillOp,
            weight: 2,
            opacity: strokeOp,
            smoothFactor: 1.5,
          }).addTo(map);

          polygon.empireId = emp.id;

          // Click handler
          polygon.on('click', function() {
            showEmpireInfo(emp);
          });

          // Hover effects
          polygon.on('mouseover', function() {
            this.setStyle({ fillOpacity: fillOp + 0.12, weight: 3, opacity: 1 });
          });
          polygon.on('mouseout', function() {
            if (!selectedEmpire || selectedEmpire.id !== emp.id) {
              this.setStyle({ fillOpacity: fillOp, weight: 2, opacity: strokeOp });
            }
          });

          activeLayers.push(polygon);
        }
      });

      // Update legend
      updateLegend(activeEmpires);

      // If selected empire is no longer visible, hide info
      if (selectedEmpire && (year < selectedEmpire.start || year > selectedEmpire.end)) {
        hideEmpireInfo();
      }
    }

    // ─── Legend ───
    function updateLegend(activeEmpires) {
      if (!legendItems || !legendEmpty) return;
      legendItems.innerHTML = '';

      if (activeEmpires.length === 0) {
        legendEmpty.style.display = '';
        return;
      }
      legendEmpty.style.display = 'none';

      // Sort by start year
      activeEmpires.sort(function(a, b) { return a.start - b.start; });

      activeEmpires.forEach(function(emp) {
        var row = document.createElement('div');
        row.className = 'legend-row';
        row.innerHTML = '<div class="legend-dot" style="background:' + emp.color + ';color:' + emp.color + '"></div>'
          + '<span>' + emp.name + '</span>'
          + '<span class="legend-date">' + formatYear(emp.start) + '</span>';
        row.addEventListener('click', function() {
          showEmpireInfo(emp);
          // Fly to empire
          var bounds = L.polygon(emp.coords).getBounds();
          map.flyToBounds(bounds, { padding: [40, 40], duration: 1 });
        });
        legendItems.appendChild(row);
      });
    }

    // ─── Empire Info Panel ───
    function showEmpireInfo(emp) {
      selectedEmpire = emp;

      if (infoEra) {
        infoEra.textContent = getEraName(emp.era);
        infoEra.style.background = hexToRgba(emp.color, 0.1);
        infoEra.style.color = emp.color;
        infoEra.style.borderColor = hexToRgba(emp.color, 0.2);
      }
      if (infoDates) infoDates.textContent = formatYear(emp.start) + ' – ' + formatYear(emp.end);
      if (infoTitle) infoTitle.textContent = emp.name;
      if (infoDesc) infoDesc.textContent = emp.description || '';
      if (infoSig) infoSig.textContent = emp.significance || '';
      if (infoCapital) infoCapital.textContent = emp.capital || '';
      if (infoRegion) infoRegion.textContent = emp.region || '';

      if (infoTags) {
        infoTags.innerHTML = '';
        (emp.tags || []).forEach(function(tag) {
          var span = document.createElement('span');
          span.className = 'atlas-info-tag';
          span.textContent = '#' + tag;
          infoTags.appendChild(span);
        });
      }

      if (infoTimelineBtn) {
        infoTimelineBtn.onclick = function() {
          window.location.href = '/timeline?year=' + emp.peakYear;
        };
      }

      if (infoPanel) infoPanel.classList.add('visible');

      // Highlight the polygon
      activeLayers.forEach(function(l) {
        if (l.empireId === emp.id) {
          l.setStyle({ fillOpacity: 0.35, weight: 3, opacity: 1 });
        } else {
          l.setStyle({ fillOpacity: 0.04, weight: 1, opacity: 0.15 });
        }
      });
    }

    function hideEmpireInfo() {
      selectedEmpire = null;
      if (infoPanel) infoPanel.classList.remove('visible');
      // Restore all polygons
      updateMapForYear(currentYear);
    }

    // ─── Year Formatting & Slider ───
    function setYear(year) {
      currentYear = Math.round(year);
      if (yearBadge) yearBadge.textContent = formatYear(currentYear);
      if (slider) {
        slider.value = String(currentYear);
        slider.setAttribute('aria-valuenow', String(currentYear));
        slider.setAttribute('aria-valuetext', formatYear(currentYear));
      }
      updateMapForYear(currentYear);
    }

    // Slider input
    if (slider) {
      slider.addEventListener('input', function() {
        setYear(parseInt(slider.value));
      });
    }

    // ─── Play/Pause ───
    function togglePlay() {
      playing = !playing;
      if (playIcon) playIcon.style.display = playing ? 'none' : '';
      if (pauseIcon) pauseIcon.style.display = playing ? '' : 'none';
      if (playBtn) playBtn.classList.toggle('playing', playing);

      if (playing) {
        playInterval = setInterval(function() {
          // Adaptive step based on era density
          var step;
          if (currentYear < -3000) step = 50 * playSpeed;
          else if (currentYear < -500) step = 25 * playSpeed;
          else if (currentYear < 500) step = 15 * playSpeed;
          else if (currentYear < 1500) step = 10 * playSpeed;
          else if (currentYear < 1800) step = 5 * playSpeed;
          else step = 2 * playSpeed;

          var next = currentYear + step;
          if (next > 2026) next = -3500;
          setYear(next);
        }, 100);
      } else {
        if (playInterval) { clearInterval(playInterval); playInterval = null; }
      }
    }

    if (playBtn) playBtn.addEventListener('click', togglePlay);

    // Speed controls
    document.querySelectorAll('.atlas-speed-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.atlas-speed-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        playSpeed = parseInt(btn.dataset.speed) || 1;
      });
    });

    // ─── Empire selector ───
    if (empireSelect) {
      empireSelect.addEventListener('change', function() {
        var empId = empireSelect.value;
        if (!empId) {
          hideEmpireInfo();
          map.flyTo([25, 30], 3, { duration: 1 });
          return;
        }

        var emp = empires.find(function(e) { return e.id === empId; });
        if (!emp) return;

        // Set year to peak
        setYear(emp.peakYear || Math.round((emp.start + emp.end) / 2));

        // Fly to bounds
        var bounds = L.polygon(emp.coords).getBounds();
        map.flyToBounds(bounds, { padding: [60, 60], duration: 1.2 });

        // Show info
        setTimeout(function() { showEmpireInfo(emp); }, 400);
      });
    }

    // ─── Era buttons ───
    document.querySelectorAll('.atlas-era-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var year = parseInt(btn.dataset.year);
        var zoom = parseInt(btn.dataset.zoom) || 3;
        setYear(year);
        map.flyTo([25, 30], zoom, { duration: 1 });
        if (playing) togglePlay();
      });
    });

    // ─── Info close ───
    if (infoClose) infoClose.addEventListener('click', hideEmpireInfo);

    // ─── Legend toggle ───
    if (legendToggle && legendPanel) {
      legendToggle.addEventListener('click', function() {
        legendPanel.classList.toggle('collapsed');
      });
    }

    // ─── Keyboard ───
    document.addEventListener('keydown', function(e) {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') return;
      if (e.key === ' ' || e.key === 'k') { e.preventDefault(); togglePlay(); }
      else if (e.key === 'ArrowLeft') { setYear(currentYear - 50); }
      else if (e.key === 'ArrowRight') { setYear(currentYear + 50); }
      else if (e.key === 'Escape') { hideEmpireInfo(); }
    });

    // ─── Initial render ───
    setYear(-500);
  }

  initAtlas().catch(console.error);
</script>
