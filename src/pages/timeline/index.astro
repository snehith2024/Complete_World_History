---
import Layout from '../../layouts/Layout.astro';
import TimelineCanvas from '../../components/timeline/TimelineCanvas.astro';
---

<Layout
  title="Sacred Timeline"
  description="Explore the sacred timeline of human civilization — from the Big Bang to the present day. A cinematic, infinitely zoomable journey through world history."
  fullscreen={true}
  noNav={true}
  noFooter={true}
>
  <div class="timeline-app">
    <!-- Top control bar -->
    <header class="tl-topbar">
      <div class="tl-topbar-left">
        <a href="/" class="tl-back" aria-label="Back to home">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <div class="tl-breadcrumb" id="tl-breadcrumb">
          <span class="tl-bc-era" id="bc-era">Ancient</span>
          <span class="tl-bc-sep">·</span>
          <span class="tl-bc-year" id="bc-year">500 BCE</span>
        </div>
      </div>

      <div class="tl-topbar-center">
        <!-- Scope toggle -->
        <div class="tl-scope-group" role="group" aria-label="Timeline Scope">
          <button class="tl-scope-btn active" data-scope="human" aria-pressed="true">Human</button>
          <button class="tl-scope-btn" data-scope="deep" aria-pressed="false">Deep</button>
          <button class="tl-scope-btn" data-scope="universe" aria-pressed="false">Universe</button>
        </div>

        <!-- Go to date -->
        <div class="tl-goto">
          <input
            type="text"
            class="tl-goto-input"
            id="goto-input"
            placeholder="Go to year... 44 BCE"
            aria-label="Navigate to specific year"
          />
        </div>

        <!-- Zoom controls -->
        <div class="tl-zoom" role="group" aria-label="Zoom controls">
          <button class="tl-zoom-btn" id="zoom-out-btn" aria-label="Zoom out" title="Zoom out">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 6h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <span class="tl-zoom-label" id="zoom-label">Eras</span>
          <button class="tl-zoom-btn" id="zoom-in-btn" aria-label="Zoom in" title="Zoom in">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M6 2v8M2 6h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="tl-topbar-right">
        <!-- Era quick-jump -->
        <div class="tl-era-nav" id="era-nav">
          <button class="tl-era-chip" data-year="-10000" title="Ancient">🏛️</button>
          <button class="tl-era-chip" data-year="-300" title="Classical">⚖️</button>
          <button class="tl-era-chip" data-year="900" title="Medieval">⚔️</button>
          <button class="tl-era-chip" data-year="1500" title="Early Modern">🗺️</button>
          <button class="tl-era-chip" data-year="1850" title="Industrial">⚙️</button>
          <button class="tl-era-chip" data-year="1960" title="Modern">🚀</button>
        </div>
      </div>
    </header>

    <!-- Main timeline canvas (fills remaining space) -->
    <div class="tl-canvas-area">
      <TimelineCanvas />
    </div>

    <!-- Minimap bar -->
    <div class="tl-minimap" id="tl-minimap">
      <div class="tl-minimap-track">
        <div class="tl-minimap-viewport" id="minimap-viewport"></div>
      </div>
      <div class="tl-minimap-labels">
        <span>Big Bang</span>
        <span>Ancient</span>
        <span>Classical</span>
        <span>Medieval</span>
        <span>Modern</span>
        <span>Now</span>
      </div>
    </div>
  </div>
</Layout>

<style>
  .timeline-app {
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
    background: #030712;
  }

  /* ─── Top Bar ─── */
  .tl-topbar {
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 0 16px;
    background: rgba(3, 7, 18, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
    z-index: 300;
  }

  .tl-topbar-left,
  .tl-topbar-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .tl-topbar-center {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    justify-content: center;
  }

  /* Back button */
  .tl-back {
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.4);
    transition: all 0.15s;
    text-decoration: none;
  }
  .tl-back:hover {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.8);
  }

  /* Breadcrumb */
  .tl-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tl-bc-era {
    font-size: 11px;
    font-weight: 600;
    color: #00dfd8;
    font-family: 'Inter', system-ui, sans-serif;
  }
  .tl-bc-sep {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.15);
  }
  .tl-bc-year {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.35);
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
  }

  /* Scope toggles */
  .tl-scope-group {
    display: flex;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 2px;
    gap: 1px;
  }
  .tl-scope-btn {
    font-size: 11px;
    padding: 4px 14px;
    border-radius: 6px;
    border: none;
    background: none;
    color: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 500;
    transition: all 0.15s;
  }
  .tl-scope-btn:hover { color: rgba(255, 255, 255, 0.7); }
  .tl-scope-btn.active {
    background: rgba(0, 223, 216, 0.1);
    color: #00dfd8;
  }

  /* Go to input */
  .tl-goto-input {
    height: 28px;
    width: 160px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 0 10px;
    font-size: 11px;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    color: rgba(255, 255, 255, 0.7);
    outline: none;
    transition: all 0.15s;
  }
  .tl-goto-input::placeholder { color: rgba(255, 255, 255, 0.2); }
  .tl-goto-input:focus {
    border-color: rgba(0, 223, 216, 0.3);
    background: rgba(0, 223, 216, 0.03);
  }

  /* Zoom controls */
  .tl-zoom {
    display: flex;
    align-items: center;
    gap: 2px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 2px;
  }
  .tl-zoom-btn {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    transition: all 0.15s;
  }
  .tl-zoom-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.8);
  }
  .tl-zoom-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.3);
    padding: 0 8px;
    min-width: 56px;
    text-align: center;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    white-space: nowrap;
  }

  /* Era quick-jump chips */
  .tl-era-nav {
    display: flex;
    gap: 2px;
  }
  .tl-era-chip {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    transition: all 0.15s;
    border: 1px solid transparent;
  }
  .tl-era-chip:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
  }

  /* ─── Canvas Area ─── */
  .tl-canvas-area {
    flex: 1;
    min-height: 0;
    position: relative;
  }

  /* ─── Minimap ─── */
  .tl-minimap {
    height: 28px;
    background: rgba(3, 7, 18, 0.9);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-shrink: 0;
    z-index: 300;
  }
  .tl-minimap-track {
    height: 3px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 2px;
    position: relative;
    margin-bottom: 3px;
  }
  .tl-minimap-viewport {
    position: absolute;
    top: -1px;
    height: 5px;
    background: rgba(0, 223, 216, 0.3);
    border-radius: 3px;
    border: 1px solid rgba(0, 223, 216, 0.4);
    transition: left 0.15s, width 0.15s;
    min-width: 8px;
  }
  .tl-minimap-labels {
    display: flex;
    justify-content: space-between;
    padding: 0 2px;
  }
  .tl-minimap-labels span {
    font-size: 7px;
    color: rgba(255, 255, 255, 0.15);
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .tl-topbar-center { display: none; }
    .tl-era-nav { display: none; }
    .tl-topbar { padding: 0 12px; height: 42px; }
  }

  @media (max-width: 480px) {
    .tl-minimap { display: none; }
  }
</style>

<script>
  // ─── Scope toggles ───
  document.querySelectorAll('.tl-scope-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tl-scope-btn').forEach(function(b) {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      var scope = btn.dataset.scope || 'human';
      document.dispatchEvent(new CustomEvent('timeline:scope-change', { detail: { scope: scope } }));
    });
  });

  // ─── Zoom buttons ───
  document.getElementById('zoom-in-btn')?.addEventListener('click', function() {
    document.dispatchEvent(new CustomEvent('timeline:zoom-in'));
  });
  document.getElementById('zoom-out-btn')?.addEventListener('click', function() {
    document.dispatchEvent(new CustomEvent('timeline:zoom-out'));
  });

  // ─── Go to date ───
  var gotoInput = document.getElementById('goto-input');
  if (gotoInput) {
    gotoInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        document.dispatchEvent(new CustomEvent('timeline:goto', {
          detail: { query: gotoInput.value.trim() }
        }));
        gotoInput.value = '';
        gotoInput.blur();
      }
    });
  }

  // ─── Era quick-jump ───
  document.querySelectorAll('.tl-era-chip').forEach(function(chip) {
    chip.addEventListener('click', function() {
      var year = parseFloat(chip.dataset.year || '0');
      document.dispatchEvent(new CustomEvent('timeline:goto', {
        detail: { query: String(year) }
      }));
    });
  });

  // ─── View update listener ───
  var bcEra = document.getElementById('bc-era');
  var bcYear = document.getElementById('bc-year');
  var zoomLabel = document.getElementById('zoom-label');
  var minimapViewport = document.getElementById('minimap-viewport');

  document.addEventListener('timeline:view-update', function(e) {
    var d = e.detail || {};
    if (bcEra && d.eraName) bcEra.textContent = d.eraName;
    if (bcYear && d.yearLabel) bcYear.textContent = d.yearLabel;
    if (zoomLabel && d.zoomLabel) zoomLabel.textContent = d.zoomLabel;

    // Update minimap viewport indicator
    if (minimapViewport) {
      // Map the full range (-13.8B to 2026) to 0-100%
      var fullStart = -13800000000;
      var fullEnd = 2026;
      var fullSpan = fullEnd - fullStart;

      var leftPct = ((d.leftYear - fullStart) / fullSpan) * 100;
      var rightPct = ((d.rightYear - fullStart) / fullSpan) * 100;
      var widthPct = rightPct - leftPct;

      leftPct = Math.max(0, Math.min(100, leftPct));
      widthPct = Math.max(0.3, Math.min(100 - leftPct, widthPct));

      minimapViewport.style.left = leftPct + '%';
      minimapViewport.style.width = widthPct + '%';
    }
  });

  // ─── Sync scope from external events ───
  document.addEventListener('timeline:scope-change', function(e) {
    var scope = (e.detail || {}).scope;
    document.querySelectorAll('.tl-scope-btn').forEach(function(b) {
      var active = b.dataset.scope === scope;
      b.classList.toggle('active', active);
      b.setAttribute('aria-pressed', String(active));
    });
  });
</script>
