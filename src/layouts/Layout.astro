---
import '../styles/global.css';
import NavBar from '../components/layout/NavBar.astro';
import Footer from '../components/layout/Footer.astro';
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  noNav?: boolean;
  noFooter?: boolean;
  fullscreen?: boolean;
}

const {
  title = 'Complete World History',
  description = 'Explore the complete history of humanity from the Big Bang to the present day. An infinitely zoomable, interactive timeline of world civilizations, events, and historical figures.',
  image = '/og-image.png',
  noNav = false,
  noFooter = false,
  fullscreen = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://allworldhistory.com');
const pageTitle = title === 'Complete World History' ? title : `${title} — Complete World History`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Complete World History" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Complete World History" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Complete World History",
      "url": "https://allworldhistory.com",
      "description": description,
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://allworldhistory.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Skip to content -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    {!noNav && <NavBar />}

    <main id="main-content" class={fullscreen ? 'fullscreen-main' : ''}>
      <slot />
    </main>

    {!noFooter && <Footer />}

    <style>
      .fullscreen-main {
        height: 100vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
    </style>
    <Analytics />
  </body>
</html>
