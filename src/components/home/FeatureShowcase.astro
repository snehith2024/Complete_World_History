---
const features = [
  {
    id: 'infinite-zoom',
    icon: '∞',
    title: 'Infinite Zoom Timeline',
    description: 'Zoom from the Big Bang to yesterday. Smooth D3-powered canvas with mouse wheel & pinch zoom.',
    color: '#007cf0',
    gradient: 'var(--gradient-develop)',
    link: '/timeline',
    demo: 'timeline',
    tags: ['Zoom', 'Interactive', 'D3.js'],
  },
  {
    id: 'historical-map',
    icon: '🗺️',
    title: 'Interactive Historical Map',
    description: 'Watch empires rise and fall on a living map. Time-slider changes political boundaries across history.',
    color: '#50e3c2',
    gradient: 'linear-gradient(135deg, #50e3c2, #007cf0)',
    link: '/map',
    demo: 'map',
    tags: ['Map', 'Borders', 'Animated'],
  },
  {
    id: 'civilization-explorer',
    icon: '🏛️',
    title: 'Civilization Explorer',
    description: 'Deep-dive into 127+ civilizations — timelines, maps, figures, and relationships.',
    color: '#f5a623',
    gradient: 'var(--gradient-ship)',
    link: '/civilizations',
    demo: 'civs',
    tags: ['Civilizations', 'Parallel', 'Context'],
  },
  {
    id: 'knowledge-graph',
    icon: '◈',
    title: 'Knowledge Graph',
    description: 'Visually navigate history through interconnected nodes — people, empires, religions, inventions.',
    color: '#7928ca',
    gradient: 'var(--gradient-preview)',
    link: '/knowledge-graph',
    demo: 'graph',
    tags: ['Graph', 'Connections', 'D3.js'],
  },
  {
    id: 'comparison',
    icon: '⇌',
    title: 'History Comparison',
    description: 'Compare Roman Empire vs Han Dynasty. See what was happening simultaneously across the world.',
    color: '#ff4d4d',
    gradient: 'linear-gradient(135deg, #ff4d4d, #7928ca)',
    link: '/compare',
    demo: 'compare',
    tags: ['Compare', 'Parallel', 'Side-by-side'],
  },
  {
    id: 'layers',
    icon: '⊞',
    title: '8 Timeline Layers',
    description: 'Filter by Political, Military, Religious, Scientific, Economic, Cultural, and more.',
    color: '#00dfd8',
    gradient: 'linear-gradient(135deg, #00dfd8, #7928ca)',
    link: '/timeline#layers',
    demo: 'layers',
    tags: ['Layers', 'Filter', 'Customize'],
  },
  {
    id: 'ai-assistant',
    icon: '✦',
    title: 'AI History Assistant',
    description: 'Ask any historical question. The AI understands your current timeline context automatically.',
    color: '#f9cb28',
    gradient: 'linear-gradient(135deg, #f9cb28, #ff0080)',
    link: '/timeline',
    demo: 'ai',
    tags: ['AI', 'Chat', 'Context-aware'],
  },
  {
    id: 'on-this-day',
    icon: '📅',
    title: 'On This Day',
    description: 'Discover what happened on today\'s date throughout history — births, deaths, discoveries.',
    color: '#aaffec',
    gradient: 'linear-gradient(135deg, #aaffec, #007cf0)',
    link: '/on-this-day',
    demo: 'otd',
    tags: ['Daily', 'Calendar', 'Discovery'],
  },
];
---

<section class="features-section section" aria-labelledby="features-heading">
  <div class="container">
    <div class="features-header">
      <p class="eyebrow">10 powerful features</p>
      <h2 id="features-heading" class="text-display-lg features-title">
        History, reimagined.
      </h2>
      <p class="text-body-lg features-body">
        Not a wiki. Not a textbook. An OS for human history.
      </p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => (
        <a
          href={feature.link}
          class="feature-card animate-fade-in-up"
          id={`feature-${feature.id}`}
          style={`animation-delay: ${i * 70}ms`}
          aria-label={feature.title}
        >
          <!-- Gradient glow -->
          <div class="feature-glow" style={`background: ${feature.gradient}`} aria-hidden="true"></div>

          <div class="feature-card-inner">
            <!-- Icon -->
            <div class="feature-icon" style={`color: ${feature.color}`} aria-hidden="true">
              {feature.icon}
            </div>

            <!-- Content -->
            <div class="feature-content">
              <h3 class="feature-title text-display-sm">{feature.title}</h3>
              <p class="feature-desc text-body-sm">{feature.description}</p>
            </div>

            <!-- Tags + Arrow -->
            <div class="feature-footer">
              <div class="feature-tags">
                {feature.tags.map(tag => (
                  <span class="feature-tag text-mono">{tag}</span>
                ))}
              </div>
              <svg class="feature-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M10 5l3 3-3 3" stroke={feature.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: var(--color-bg);
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }
  .features-title { max-width: 500px; }
  .features-body { color: var(--color-body); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .feature-card {
    position: relative;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: var(--transition-normal);
    box-shadow: var(--shadow-2);
  }
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-3);
    border-color: var(--color-border-strong);
  }
  .feature-card:hover .feature-glow {
    opacity: 0.08;
  }
  .feature-card:hover .feature-arrow {
    transform: translateX(4px);
  }

  .feature-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--transition-normal);
    pointer-events: none;
  }

  .feature-card-inner {
    position: relative;
    z-index: 1;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex: 1;
  }

  .feature-icon {
    font-size: 28px;
    line-height: 1;
    font-style: normal;
  }

  .feature-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .feature-title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.4px;
    color: var(--color-ink);
  }

  .feature-desc {
    color: var(--color-body);
    font-size: 13px;
    line-height: 1.6;
  }

  .feature-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .feature-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .feature-tag {
    font-size: 10px;
    color: var(--color-mute);
    background: var(--color-bg-hover);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 1px 6px;
    letter-spacing: 0.02em;
  }

  .feature-arrow {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 1199px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 959px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 499px) {
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
