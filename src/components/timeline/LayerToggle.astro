---
// Layer Toggle component for timeline
const layers = [
  { id: 'political',    label: 'Political',    color: '#007cf0', icon: '🏛️', active: true },
  { id: 'military',     label: 'Military',     color: '#ff4d4d', icon: '⚔️', active: true },
  { id: 'religious',    label: 'Religious',    color: '#f9cb28', icon: '☯', active: true },
  { id: 'scientific',   label: 'Scientific',   color: '#50e3c2', icon: '🔬', active: false },
  { id: 'tech',         label: 'Technology',   color: '#00dfd8', icon: '⚙️', active: false },
  { id: 'economic',     label: 'Economic',     color: '#f5a623', icon: '📈', active: false },
  { id: 'cultural',     label: 'Cultural',     color: '#7928ca', icon: '🎭', active: false },
  { id: 'exploration',  label: 'Exploration',  color: '#ff0080', icon: '🗺️', active: false },
];
---

<div class="layer-toggle-wrapper" role="group" aria-label="Timeline layers">
  <button
    class="layer-toggle-trigger text-mono"
    id="layer-toggle-btn"
    aria-expanded="false"
    aria-controls="layer-dropdown"
    aria-label="Toggle timeline layers"
  >
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <rect x="1" y="1" width="10" height="2" rx="1" fill="currentColor"/>
      <rect x="1" y="5" width="10" height="2" rx="1" fill="currentColor" opacity="0.7"/>
      <rect x="1" y="9" width="10" height="2" rx="1" fill="currentColor" opacity="0.4"/>
    </svg>
    Layers
    <span class="layer-count text-mono" id="layer-count" aria-label="3 layers active">3</span>
  </button>

  <div class="layer-dropdown glass" id="layer-dropdown" aria-hidden="true">
    <div class="layer-dropdown-header">
      <span class="text-mono" style="font-size: 10px; color: var(--color-mute);">TIMELINE LAYERS</span>
      <button class="layer-select-all text-mono" id="layer-select-all">All</button>
    </div>
    {layers.map(layer => (
      <label class="layer-item" id={`layer-${layer.id}`} aria-label={`Toggle ${layer.label} layer`}>
        <input
          type="checkbox"
          class="layer-checkbox sr-only"
          checked={layer.active}
          data-layer={layer.id}
          data-color={layer.color}
        />
        <div class="layer-item-inner">
          <span class="layer-dot" style={`background: ${layer.color}; box-shadow: 0 0 6px ${layer.color}40`}></span>
          <span class="layer-icon" aria-hidden="true">{layer.icon}</span>
          <span class="layer-label text-body-sm">{layer.label}</span>
        </div>
        <div class="layer-check" aria-hidden="true">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
            <path d="M1.5 5L4 7.5L8.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </label>
    ))}
  </div>
</div>

<style>
  .layer-toggle-wrapper {
    position: relative;
  }

  .layer-toggle-trigger {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 28px;
    padding: 0 var(--space-sm);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 11px;
    color: var(--color-body);
    cursor: pointer;
    transition: var(--transition-fast);
    font-family: var(--font-mono);
  }
  .layer-toggle-trigger:hover {
    border-color: var(--color-border-strong);
    color: var(--color-ink);
  }

  .layer-count {
    font-size: 10px;
    background: var(--color-link);
    color: white;
    border-radius: var(--radius-full);
    padding: 0 5px;
    min-width: 16px;
    text-align: center;
    line-height: 16px;
  }

  .layer-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 200px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-4);
    z-index: 200;
    overflow: hidden;
    transform-origin: top right;
    transform: scale(0.95) translateY(-4px);
    opacity: 0;
    pointer-events: none;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }
  .layer-dropdown[aria-hidden="false"] {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  .layer-dropdown-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }
  .layer-select-all {
    font-size: 10px;
    color: var(--color-link);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
  }

  .layer-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px var(--space-sm);
    cursor: pointer;
    transition: background var(--transition-fast);
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .layer-item:hover { background: var(--color-bg-hover); }
  .layer-item:last-child { border-bottom: none; }

  .layer-item-inner {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .layer-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }
  .layer-icon {
    font-size: 12px;
    line-height: 1;
  }
  .layer-label {
    font-size: 13px;
    color: var(--color-body);
  }

  .layer-check {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    transition: var(--transition-fast);
    flex-shrink: 0;
  }

  .layer-checkbox:checked ~ .layer-item-inner .layer-label { color: var(--color-ink); }
  .layer-checkbox:checked + .layer-item-inner + .layer-check,
  .layer-item:has(.layer-checkbox:checked) .layer-check {
    background: var(--color-link);
    border-color: var(--color-link);
    color: white;
  }
</style>

<script>
  const trigger = document.getElementById('layer-toggle-btn');
  const dropdown = document.getElementById('layer-dropdown');
  const countBadge = document.getElementById('layer-count');

  function updateCount() {
    const checked = document.querySelectorAll('.layer-checkbox:checked').length;
    if (countBadge) countBadge.textContent = String(checked);
  }

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdown?.getAttribute('aria-hidden') === 'false';
    dropdown?.setAttribute('aria-hidden', String(isOpen));
    trigger.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!trigger?.contains(e.target as Node) && !dropdown?.contains(e.target as Node)) {
      dropdown?.setAttribute('aria-hidden', 'true');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // Checkbox change
  document.querySelectorAll('.layer-checkbox').forEach(cb => {
    cb.addEventListener('change', () => {
      updateCount();
      const layerId = (cb as HTMLInputElement).dataset.layer ?? '';
      const isActive = (cb as HTMLInputElement).checked;
      document.dispatchEvent(new CustomEvent('timeline:layer-toggle', {
        detail: { layer: layerId, active: isActive }
      }));
    });
  });

  // Select all
  document.getElementById('layer-select-all')?.addEventListener('click', () => {
    const allChecked = document.querySelectorAll('.layer-checkbox:checked').length
      === document.querySelectorAll('.layer-checkbox').length;
    document.querySelectorAll('.layer-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = !allChecked;
    });
    updateCount();
  });
</script>
